<script>
// ============================================================
// BST - Árvore Binária de Busca
// ============================================================
class BSTNode {
  constructor(v) { this.val = v; this.left = this.right = null; }
}

class BST {
  constructor() { this.root = null; }

  insert(v) { this.root = this._ins(this.root, v); }
  _ins(n, v) {
    if (!n) return new BSTNode(v);
    if (v < n.val) n.left = this._ins(n.left, v);
    else if (v > n.val) n.right = this._ins(n.right, v);
    return n;
  }

  remove(v) { this.root = this._rem(this.root, v); }
  _rem(n, v) {
    if (!n) return null;
    if (v < n.val) n.left = this._rem(n.left, v);
    else if (v > n.val) n.right = this._rem(n.right, v);
    else {
      if (!n.left) return n.right;
      if (!n.right) return n.left;
      let m = n.right;
      while (m.left) m = m.left;
      n.val = m.val;
      n.right = this._rem(n.right, m.val);
    }
    return n;
  }

  search(v) {
    let n = this.root;
    while (n) {
      if (v === n.val) return true;
      n = v < n.val ? n.left : n.right;
    }
    return false;
  }

  height(n = this.root) {
    if (!n) return 0;
    return 1 + Math.max(this.height(n.left), this.height(n.right));
  }

  count(n = this.root) {
    if (!n) return 0;
    return 1 + this.count(n.left) + this.count(n.right);
  }
}

// ============================================================
// AVL - Árvore AVL Auto-Balanceada
// ============================================================
class AVLNode {
  constructor(v) { this.val = v; this.left = this.right = null; this.h = 1; }
}

class AVL {
  constructor() { this.root = null; }

  _h(n) { return n ? n.h : 0; }
  _upd(n) { n.h = 1 + Math.max(this._h(n.left), this._h(n.right)); }
  _bf(n) { return n ? this._h(n.left) - this._h(n.right) : 0; }

  _rotR(y) {
    let x = y.left, T = x.right;
    x.right = y; y.left = T;
    this._upd(y); this._upd(x);
    return x;
  }

  _rotL(x) {
    let y = x.right, T = y.left;
    y.left = x; x.right = T;
    this._upd(x); this._upd(y);
    return y;
  }

  _bal(n) {
    this._upd(n);
    let b = this._bf(n);
    if (b > 1 && this._bf(n.left) >= 0) return this._rotR(n);
    if (b > 1 && this._bf(n.left) < 0) { n.left = this._rotL(n.left); return this._rotR(n); }
    if (b < -1 && this._bf(n.right) <= 0) return this._rotL(n);
    if (b < -1 && this._bf(n.right) > 0) { n.right = this._rotR(n.right); return this._rotL(n); }
    return n;
  }

  insert(v) { this.root = this._ins(this.root, v); }
  _ins(n, v) {
    if (!n) return new AVLNode(v);
    if (v < n.val) n.left = this._ins(n.left, v);
    else if (v > n.val) n.right = this._ins(n.right, v);
    return this._bal(n);
  }

  remove(v) { this.root = this._rem(this.root, v); }
  _rem(n, v) {
    if (!n) return null;
    if (v < n.val) n.left = this._rem(n.left, v);
    else if (v > n.val) n.right = this._rem(n.right, v);
    else {
      if (!n.left) return n.right;
      if (!n.right) return n.left;
      let m = n.right;
      while (m.left) m = m.left;
      n.val = m.val;
      n.right = this._rem(n.right, m.val);
    }
    return this._bal(n);
  }

  search(v) {
    let n = this.root;
    while (n) {
      if (v === n.val) return true;
      n = v < n.val ? n.left : n.right;
    }
    return false;
  }

  height(n = this.root) { return this._h(n); }

  isBalanced(n = this.root) {
    if (!n) return true;
    return Math.abs(this._bf(n)) <= 1 && this.isBalanced(n.left) && this.isBalanced(n.right);
  }

  count(n = this.root) {
    if (!n) return 0;
    return 1 + this.count(n.left) + this.count(n.right);
  }
}

// ============================================================
// Rubro-Negra (Red-Black Tree)
// ============================================================
const RED = true, BLACK = false;

class RBNode {
  constructor(v) { this.val = v; this.left = this.right = null; this.color = RED; this.p = null; }
}

class RBT {
  constructor() {
    this.NIL = new RBNode(null);
    this.NIL.color = BLACK;
    this.root = this.NIL;
  }

  _isR(n) { return n && n !== this.NIL && n.color === RED; }

  insert(v) {
    let z = new RBNode(v);
    z.left = z.right = z.p = this.NIL;
    let y = this.NIL, x = this.root;
    while (x !== this.NIL) { y = x; x = z.val < x.val ? x.left : x.right; }
    z.p = y;
    if (y === this.NIL) this.root = z;
    else if (z.val < y.val) y.left = z;
    else y.right = z;
    this._fixIns(z);
  }

  _fixIns(z) {
    while (this._isR(z.p)) {
      if (z.p === z.p.p.left) {
        let y = z.p.p.right;
        if (this._isR(y)) { z.p.color = BLACK; y.color = BLACK; z.p.p.color = RED; z = z.p.p; }
        else {
          if (z === z.p.right) { z = z.p; this._rotL(z); }
          z.p.color = BLACK; z.p.p.color = RED; this._rotR(z.p.p);
        }
      } else {
        let y = z.p.p.left;
        if (this._isR(y)) { z.p.color = BLACK; y.color = BLACK; z.p.p.color = RED; z = z.p.p; }
        else {
          if (z === z.p.left) { z = z.p; this._rotR(z); }
          z.p.color = BLACK; z.p.p.color = RED; this._rotL(z.p.p);
        }
      }
    }
    this.root.color = BLACK;
  }

  _rotL(x) {
    let y = x.right; x.right = y.left;
    if (y.left !== this.NIL) y.left.p = x;
    y.p = x.p;
    if (x.p === this.NIL) this.root = y;
    else if (x === x.p.left) x.p.left = y;
    else x.p.right = y;
    y.left = x; x.p = y;
  }

  _rotR(x) {
    let y = x.left; x.left = y.right;
    if (y.right !== this.NIL) y.right.p = x;
    y.p = x.p;
    if (x.p === this.NIL) this.root = y;
    else if (x === x.p.right) x.p.right = y;
    else x.p.left = y;
    y.right = x; x.p = y;
  }

  _min(n) { while (n.left !== this.NIL) n = n.left; return n; }

  _trans(u, v) {
    if (u.p === this.NIL) this.root = v;
    else if (u === u.p.left) u.p.left = v;
    else u.p.right = v;
    v.p = u.p;
  }

  remove(v) {
    let z = this._find(v);
    if (z === this.NIL) return;
    let y = z, oc = y.color, x;
    if (z.left === this.NIL) { x = z.right; this._trans(z, z.right); }
    else if (z.right === this.NIL) { x = z.left; this._trans(z, z.left); }
    else {
      y = this._min(z.right); oc = y.color; x = y.right;
      if (y.p === z) x.p = y;
      else { this._trans(y, y.right); y.right = z.right; y.right.p = y; }
      this._trans(z, y); y.left = z.left; y.left.p = y; y.color = z.color;
    }
    if (oc === BLACK) this._fixDel(x);
  }

  _fixDel(x) {
    while (x !== this.root && x.color === BLACK) {
      if (x === x.p.left) {
        let w = x.p.right;
        if (w.color === RED) { w.color = BLACK; x.p.color = RED; this._rotL(x.p); w = x.p.right; }
        if (w.left.color === BLACK && w.right.color === BLACK) { w.color = RED; x = x.p; }
        else {
          if (w.right.color === BLACK) { w.left.color = BLACK; w.color = RED; this._rotR(w); w = x.p.right; }
          w.color = x.p.color; x.p.color = BLACK; w.right.color = BLACK; this._rotL(x.p); x = this.root;
        }
      } else {
        let w = x.p.left;
        if (w.color === RED) { w.color = BLACK; x.p.color = RED; this._rotR(x.p); w = x.p.left; }
        if (w.right.color === BLACK && w.left.color === BLACK) { w.color = RED; x = x.p; }
        else {
          if (w.left.color === BLACK) { w.right.color = BLACK; w.color = RED; this._rotL(w); w = x.p.left; }
          w.color = x.p.color; x.p.color = BLACK; w.left.color = BLACK; this._rotR(x.p); x = this.root;
        }
      }
    }
    x.color = BLACK;
  }

  _find(v) {
    let n = this.root;
    while (n !== this.NIL) {
      if (v === n.val) return n;
      n = v < n.val ? n.left : n.right;
    }
    return this.NIL;
  }

  search(v) { return this._find(v) !== this.NIL; }
  height(n = this.root) {
    if (!n || n === this.NIL) return 0;
    return 1 + Math.max(this.height(n.left), this.height(n.right));
  }
  blackHeight(n = this.root) {
    if (!n || n === this.NIL) return 1;
    return (n.color === BLACK ? 1 : 0) + this.blackHeight(n.left);
  }
  count(n = this.root) {
    if (!n || n === this.NIL) return 0;
    return 1 + this.count(n.left) + this.count(n.right);
  }
}

// ============================================================
// Desenho das árvores com SVG
// ============================================================
function drawTree(svgId, root, type, nil) {
  const svg = document.getElementById(svgId);
  const W = svg.clientWidth || 700, H = 240;
  svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
  svg.innerHTML = '';
  if (!root || root === nil) return;

  const nodes = [];
  function layout(n, depth, lo, hi) {
    if (!n || n === nil) return;
    const x = (lo + hi) / 2, y = 30 + depth * 50;
    nodes.push({ n, x, y });
    layout(n.left, depth + 1, lo, (lo + hi) / 2);
    layout(n.right, depth + 1, (lo + hi) / 2, hi);
  }
  layout(root, 0, 0, W);

  const map = new Map(nodes.map(d => [d.n, d]));

  // Arestas
  nodes.forEach(({ n, x, y }) => {
    ['left', 'right'].forEach(side => {
      const child = n[side];
      if (child && child !== nil && map.has(child)) {
        const c = map.get(child);
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', x); line.setAttribute('y1', y);
        line.setAttribute('x2', c.x); line.setAttribute('y2', c.y);
        line.setAttribute('stroke', '#ccc'); line.setAttribute('stroke-width', '1.5');
        svg.appendChild(line);
      }
    });
  });

  // Nós
  nodes.forEach(({ n, x, y }) => {
    const isRed = type === 'rbn' && n.color === RED;
    const fill = isRed ? '#ffdcdc' : '#dceeff';
    const stroke = isRed ? '#cc4444' : '#4488cc';
    const tc = isRed ? '#aa1111' : '#1155aa';

    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    circle.setAttribute('cx', x); circle.setAttribute('cy', y); circle.setAttribute('r', 18);
    circle.setAttribute('fill', fill); circle.setAttribute('stroke', stroke); circle.setAttribute('stroke-width', '1.5');
    svg.appendChild(circle);

    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    text.setAttribute('x', x); text.setAttribute('y', y + 4);
    text.setAttribute('text-anchor', 'middle'); text.setAttribute('font-size', '11');
    text.setAttribute('fill', tc); text.setAttribute('font-weight', 'bold');
    text.textContent = n.val;
    svg.appendChild(text);
  });
}

// ============================================================
// Controles BST
// ============================================================
const bst = new BST();
function bstLog(m) { const el = document.getElementById('bst-log'); el.textContent += '\n' + m; el.scrollTop = el.scrollHeight; }
function bstUpdate() {
  document.getElementById('bst-h').textContent = bst.height();
  document.getElementById('bst-n').textContent = bst.count();
  drawTree('bst-svg', bst.root, 'bst', null);
}
function bstInsert() { const v = parseInt(document.getElementById('bst-val').value); if (isNaN(v)) return; bst.insert(v); bstLog('Inserido: ' + v); bstUpdate(); }
function bstRemove() { const v = parseInt(document.getElementById('bst-val').value); if (isNaN(v)) return; bst.remove(v); bstLog('Removido: ' + v); bstUpdate(); }
function bstSearch() { const v = parseInt(document.getElementById('bst-val').value); const f = bst.search(v); document.getElementById('bst-res').textContent = f ? 'Encontrado ✓' : 'Não encontrado'; bstLog('Busca ' + v + ': ' + (f ? '✓' : '✗')); }
function bstClear() { bst.root = null; document.getElementById('bst-log').textContent = 'Árvore limpa.'; document.getElementById('bst-res').textContent = '—'; bstUpdate(); }

// ============================================================
// Controles AVL
// ============================================================
const avl = new AVL();
function avlLog(m) { const el = document.getElementById('avl-log'); el.textContent += '\n' + m; el.scrollTop = el.scrollHeight; }
function avlUpdate() {
  document.getElementById('avl-h').textContent = avl.height();
  document.getElementById('avl-n').textContent = avl.count();
  document.getElementById('avl-bal').textContent = avl.isBalanced() ? 'Sim ✓' : 'Não ✗';
  drawTree('avl-svg', avl.root, 'avl', null);
}
function avlInsert() { const v = parseInt(document.getElementById('avl-val').value); if (isNaN(v)) return; avl.insert(v); avlLog('Inserido: ' + v + ' (rotações aplicadas se necessário)'); avlUpdate(); }
function avlRemove() { const v = parseInt(document.getElementById('avl-val').value); if (isNaN(v)) return; avl.remove(v); avlLog('Removido: ' + v); avlUpdate(); }
function avlSearch() { const v = parseInt(document.getElementById('avl-val').value); const f = avl.search(v); avlLog('Busca ' + v + ': ' + (f ? '✓ Encontrado' : '✗ Não encontrado')); }
