<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Árvores e Caixeiro Viajante</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: Arial, sans-serif; background: #f4f4f4; color: #222; padding: 20px; }
  h1 { font-size: 22px; margin-bottom: 16px; }
  .tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 16px; }
  .tab { padding: 7px 16px; border: 1px solid #bbb; border-radius: 8px; cursor: pointer; font-size: 13px; background: #fff; }
  .tab.active { background: #e0e8ff; border-color: #5577cc; font-weight: bold; }
  .panel { display: none; }
  .panel.active { display: block; }
  .card { background: #fff; border: 1px solid #ddd; border-radius: 12px; padding: 16px 20px; margin-bottom: 12px; }
  .row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px; }
  .metric { background: #f0f0f0; border-radius: 8px; padding: 10px 14px; flex: 1; min-width: 100px; }
  .metric-label { font-size: 12px; color: #666; margin-bottom: 4px; }
  .metric-val { font-size: 20px; font-weight: bold; }
  .input-row { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-bottom: 12px; }
  input[type=number] { width: 90px; padding: 6px 8px; border: 1px solid #bbb; border-radius: 8px; font-size: 13px; }
  button { padding: 6px 14px; border: 1px solid #bbb; border-radius: 8px; cursor: pointer; background: #fff; font-size: 13px; }
  button:hover { background: #eee; }
  button.primary { background: #dceeff; border-color: #4488cc; color: #1155aa; }
  .log { font-family: monospace; font-size: 12px; background: #f8f8f8; border-radius: 8px; padding: 10px; max-height: 200px; overflow-y: auto; white-space: pre-wrap; color: #555; margin-top: 8px; border: 1px solid #eee; }
  .tree-svg { width: 100%; overflow: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th, td { padding: 7px 10px; text-align: left; border-bottom: 1px solid #eee; }
  th { color: #555; font-weight: bold; background: #f9f9f9; }
  .section-title { font-size: 15px; font-weight: bold; margin-bottom: 10px; color: #333; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 6px; font-size: 11px; margin-right: 6px; }
  .badge-b { background: #dceeff; color: #1155aa; }
  .badge-r { background: #ffdcdc; color: #aa1111; }
</style>
</head>
