// ============================================================
// TSP - Caixeiro Viajante (Nearest Neighbor)
// ============================================================
function dist(a, b) { return Math.hypot(a.x - b.x, a.y - b.y); }

function tspNN(cities) {
  const n = cities.length;
  const visited = new Array(n).fill(false);
  let cur = 0, route = [0], total = 0;
  visited[0] = true;
  for (let i = 1; i < n; i++) {
    let best = -1, bd = Infinity;
    for (let j = 0; j < n; j++) {
      if (!visited[j]) {
        const d = dist(cities[cur], cities[j]);
        if (d < bd) { bd = d; best = j; }
      }
    }
    visited[best] = true;
    total += bd;
    route.push(best);
    cur = best;
  }
  total += dist(cities[cur], cities[0]);
  route.push(0);
  return { route, total };
}

let tspCities = [];

function tspRun() {
  const n = parseInt(document.getElementById('tsp-n').value) || 12;
  tspCities = Array.from({ length: n }, () => ({ x: Math.random() * 560 + 20, y: Math.random() * 260 + 30 }));
  const t0 = performance.now();
  const { route, total } = tspNN(tspCities);
  const t1 = performance.now();
  document.getElementById('tsp-cities').textContent = n;
  document.getElementById('tsp-dist').textContent = total.toFixed(1);
  document.getElementById('tsp-time').textContent = (t1 - t0).toFixed(3);
  drawTSP(route);
}

function drawTSP(route) {
  const svg = document.getElementById('tsp-svg');
  const W = svg.clientWidth || 700;
  svg.setAttribute('viewBox', `0 0 ${W} 320`);
  svg.innerHTML = '';

  for (let i = 0; i < route.length - 1; i++) {
    const a = tspCities[route[i]], b = tspCities[route[i + 1]];
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', a.x * W / 600); line.setAttribute('y1', a.y);
    line.setAttribute('x2', b.x * W / 600); line.setAttribute('y2', b.y);
    line.setAttribute('stroke', '#4488cc'); line.setAttribute('stroke-width', '1.5');
    svg.appendChild(line);
  }

  tspCities.forEach((c, i) => {
    const cx = c.x * W / 600, cy = c.y;
    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    circle.setAttribute('cx', cx); circle.setAttribute('cy', cy);
    circle.setAttribute('r', i === 0 ? 9 : 5);
    circle.setAttribute('fill', i === 0 ? '#ffdcdc' : '#dceeff');
    circle.setAttribute('stroke', i === 0 ? '#cc4444' : '#4488cc');
    circle.setAttribute('stroke-width', '1.5');
    svg.appendChild(circle);

    const t = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    t.setAttribute('x', cx + 9); t.setAttribute('y', cy + 4);
    t.setAttribute('font-size', '10'); t.setAttribute('fill', '#888');
    t.textContent = i;
    svg.appendChild(t);
  });
}

function tspClear() {
  document.getElementById('tsp-svg').innerHTML = '';
  tspCities = [];
  ['tsp-cities', 'tsp-dist', 'tsp-time'].forEach(id => document.getElementById(id).textContent = '—');
}

// ============================================================
// Experimentos estatísticos — 30 execuções × 3 tamanhos
// ============================================================
function runExperiments() {
  const sizes = [10, 100, 1000];
  const RUNS = 30;
  document.getElementById('exp-progress').textContent = 'Executando ' + (RUNS * sizes.length) + ' experimentos...';

  const results = [];
  sizes.forEach(n => {
    const times = [];
    for (let r = 0; r < RUNS; r++) {
      const cities = Array.from({ length: n }, () => ({ x: Math.random() * 1000, y: Math.random() * 1000 }));
      const t0 = performance.now();
      tspNN(cities);
      const t1 = performance.now();
      times.push(t1 - t0);
    }
    times.sort((a, b) => a - b);
    const mean = times.reduce((s, x) => s + x, 0) / RUNS;
    const variance = times.reduce((s, x) => s + (x - mean) ** 2, 0) / RUNS;
    const std = Math.sqrt(variance);
    const median = RUNS % 2 === 0
      ? (times[RUNS / 2 - 1] + times[RUNS / 2]) / 2
      : times[Math.floor(RUNS / 2)];
    results.push({ n, mean, std, min: times[0], max: times[RUNS - 1], median });
  });

  document.getElementById('exp-progress').textContent =
    'Concluído: ' + RUNS + ' execuções × ' + sizes.length + ' tamanhos = ' + (RUNS * sizes.length) + ' experimentos totais.';

  const tbody = document.getElementById('exp-tbody');
  tbody.innerHTML = results.map(r =>
    `<tr>
      <td>${r.n} cidades</td>
      <td>${r.mean.toFixed(4)}</td>
      <td>${r.std.toFixed(4)}</td>
      <td>${r.min.toFixed(4)}</td>
      <td>${r.max.toFixed(4)}</td>
      <td>${r.median.toFixed(4)}</td>
    </tr>`
  ).join('');

  drawExpChart(results);
}

function drawExpChart(results) {
  const canvas = document.getElementById('exp-chart');
  if (!canvas.getContext) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width = canvas.parentElement.clientWidth || 700, H = canvas.height = 200;
  ctx.clearRect(0, 0, W, H);

  const maxVal = Math.max(...results.map(r => r.max));
  const pad = { l: 70, r: 20, t: 20, b: 50 };
  const cW = W - pad.l - pad.r, cH = H - pad.t - pad.b;

  // Eixos
  ctx.strokeStyle = '#ccc'; ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(pad.l, pad.t); ctx.lineTo(pad.l, pad.t + cH);
  ctx.lineTo(pad.l + cW, pad.t + cH); ctx.stroke();

  // Barras + barras de erro
  const bw = Math.min(80, cW / results.length * 0.5);
  results.forEach((r, i) => {
    const bx = pad.l + (i + 0.5) * cW / results.length - bw / 2;
    const bh = r.mean / maxVal * cH;
    const by = pad.t + cH - bh;

    // Barra
    ctx.fillStyle = 'rgba(68, 136, 220, 0.5)';
    ctx.fillRect(bx, by, bw, bh);
    ctx.strokeStyle = '#4488cc'; ctx.lineWidth = 1;
    ctx.strokeRect(bx, by, bw, bh);

    // Barra de erro (±1 desvio padrão)
    const errH = r.std / maxVal * cH;
    ctx.strokeStyle = '#cc4444'; ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(bx + bw / 2, by - errH); ctx.lineTo(bx + bw / 2, by + errH); ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(bx + bw / 2 - 6, by - errH); ctx.lineTo(bx + bw / 2 + 6, by - errH);
    ctx.moveTo(bx + bw / 2 - 6, by + errH); ctx.lineTo(bx + bw / 2 + 6, by + errH);
    ctx.stroke();

    // Rótulos
    ctx.fillStyle = '#555'; ctx.font = '11px Arial'; ctx.textAlign = 'center';
    ctx.fillText(r.n + ' cidades', bx + bw / 2, pad.t + cH + 20);
    ctx.fillText(r.mean.toFixed(3) + 'ms', bx + bw / 2, by - errH - 6);
  });

  // Título eixo Y
  ctx.save();
  ctx.translate(14, pad.t + cH / 2);
  ctx.rotate(-Math.PI / 2);
  ctx.fillStyle = '#666'; ctx.font = '11px Arial'; ctx.textAlign = 'center';
  ctx.fillText('tempo médio (ms)', 0, 0);
  ctx.restore();

  // Legenda
  ctx.fillStyle = 'rgba(68, 136, 220, 0.5)';
  ctx.fillRect(pad.l, pad.t + cH + 30, 12, 12);
  ctx.fillStyle = '#555'; ctx.font = '11px Arial'; ctx.textAlign = 'left';
  ctx.fillText('média', pad.l + 16, pad.t + cH + 41);
  ctx.strokeStyle = '#cc4444'; ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(pad.l + 80, pad.t + cH + 36); ctx.lineTo(pad.l + 92, pad.t + cH + 36); ctx.stroke();
  ctx.fillStyle = '#555';
  ctx.fillText('±1 desvio padrão', pad.l + 96, pad.t + cH + 41);
}

